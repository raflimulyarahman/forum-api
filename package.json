    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.0",
    "node-pg-migrate": "^7.7.0",
    "nodemon": "^3.1.4",
    "vitest": "^2.1.0"
  }
}
