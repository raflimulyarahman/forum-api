{
  "name": "forum-api",
  "version": "1.0.0",
  "description": "Forum API - Dicoding Backend Expert Submission",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "start:dev": "nodemon src/app.js",
